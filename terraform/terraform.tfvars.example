# ═══════════════════════════════════════════════════════════════════════════════
# Terraform Değişkenleri — terraform.tfvars örneği
# Bu dosyayı kopyalayıp terraform.tfvars olarak kaydedin
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Genel ────────────────────────────────────────────────────────────────────
project_name = "marketplace"
environment  = "dev"
aws_region   = "eu-central-1"

# ─── Domain ───────────────────────────────────────────────────────────────────
domain_name = "iluvcode.art"

# ─── Cloudflare (CloudFront yerine) ──────────────────────────────────────────
# Dashboard → Overview → sağ alt köşede Account ID
cloudflare_account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"
# API Tokens → Create Token → Edit zone DNS + Zone Settings
cloudflare_api_token  = "YOUR_CLOUDFLARE_API_TOKEN"

# ─── Veritabanı ──────────────────────────────────────────────────────────────
db_password       = "YOUR_SECURE_PASSWORD_HERE"
db_instance_class = "db.t3.micro"

# ─── Ödeme ───────────────────────────────────────────────────────────────────
stripe_secret_key     = "sk_test_..."
stripe_webhook_secret = "whsec_..."
easypost_api_key      = "EZTK..."
easypost_webhook_secret = "..."

# ─── AI ──────────────────────────────────────────────────────────────────────
# Google AI Studio: aistudio.google.com/apikey
gemini_api_key = "AIzaSy..."
gemini_model   = "gemini-2.5-pro"

# ─── Auth ────────────────────────────────────────────────────────────────────
jwt_secret = "YOUR_JWT_SECRET_MIN_32_CHARS_HERE!!"
